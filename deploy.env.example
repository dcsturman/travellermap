# Copy to `deploy.env` (gitignored) and fill in. `deploy.sh` sources this;
# any value can also be overridden by exporting it in the environment.

PROJECT_ID=your-gcp-project-id          # required
REGION=us-central1                      # Cloud Run + Artifact Registry region
SERVICE=travellermap                    # Cloud Run service name
REPO=travellermap                       # Artifact Registry (docker) repo name
DOMAIN=travellermap.callistoflight.com  # the custom domain (mapped once; see DEPLOY.md)

# Runtime sizing (the whole dataset lives in RAM; 1Gi is comfortable).
MEMORY=1Gi
CPU=1
MAX_INSTANCES=4
