# Copy to `scripts/deploy.env` (gitignored) and fill in. `scripts/deploy.sh`
# sources this; any value can also be overridden by exporting it in the environment.

PROJECT_ID=your-gcp-project-id          # required
REGION=us-central1                      # Cloud Run + Artifact Registry region
SERVICE=travellermap                    # Cloud Run service name
REPO=travellermap                       # Artifact Registry (docker) repo name
DOMAIN=travellermap.callistoflight.com  # the custom domain (mapped once; see DEPLOY.md)

# Runtime sizing (the whole dataset lives in RAM; 1Gi is comfortable).
MEMORY=1Gi
CPU=1
MAX_INSTANCES=4

# CDN (Cloudflare) — optional. Set both to let deploy.sh purge the edge cache
# after each deploy, so a data change goes live immediately. Leave blank to skip
# (the deploy still works; cached sectors just expire on their own TTL).
# See DEPLOY.md › "CDN (Cloudflare)" for how to obtain these.
#   CF_ZONE_ID   — zone id for callistoflight.com (Cloudflare dashboard › Overview)
#   CF_API_TOKEN — token scoped to Zone › Cache Purge › Purge for that zone
CF_ZONE_ID=
CF_API_TOKEN=
